(* ================================================================ *)
(* Functional Pascal v1 — Formal Grammar                            *)
(* Notation: ISO 14977 EBNF                                        *)
(*                                                                  *)
(*   =    definition       ;    end of rule                         *)
(*   |    alternation      [ ]  optional (0 or 1)                   *)
(*   { }  repetition       ( )  grouping                            *)
(*   '…'  terminal string  (* … *)  comment                        *)
(*                                                                  *)
(* Keywords are case-insensitive: 'begin' matches BEGIN, Begin, etc *)
(* ================================================================ *)


(* ================================================================ *)
(* PART 1 — LEXICAL GRAMMAR                                        *)
(* ================================================================ *)

(* ---- Characters ------------------------------------------------ *)

letter          = 'A' .. 'Z' | 'a' .. 'z' | '_' ;
digit           = '0' .. '9' ;
hex_digit       = digit | 'A' .. 'F' | 'a' .. 'f' ;

(* ---- Identifiers ----------------------------------------------- *)

identifier      = letter { letter | digit } ;

(* Case-insensitive: Foo, foo, FOO all refer to the same name.     *)
(* No maximum length.                                               *)

(* ---- Number Literals ------------------------------------------- *)

decimal_digits  = digit { [ '_' ] digit } ;
hex_digits      = hex_digit { [ '_' ] hex_digit } ;

integer_literal = decimal_digits
                | '$' hex_digits ;

real_literal    = decimal_digits '.' decimal_digits [ exponent ] ;
exponent        = ( 'e' | 'E' ) [ '+' | '-' ] decimal_digits ;

(* Digits required on BOTH sides of '.': 0.5 is valid, .5 is not.  *)
(* Negative numbers are unary minus applied to a literal: -42.      *)

(* ---- String Literals ------------------------------------------- *)

string_literal  = string_element { string_element } ;
string_element  = quoted_string | char_code ;

quoted_string   = "'" { string_char | "''" } "'" ;
string_char     = (* any character except unescaped single quote *) ;

char_code       = '#' decimal_digits ;

(* Strings may span multiple lines.                                 *)
(* Doubled apostrophe is the escape for a literal quote: 'It''s'.   *)
(* Char codes use decimal ASCII: #65 = 'A', #13#10 = CR+LF.        *)
(* Adjacent elements auto-concatenate: 'Hello'#13#10'World'.        *)
(* No maximum length.                                               *)

(* ---- Comments (discarded by lexer) ----------------------------- *)

brace_comment   = '{' { (* any char except '}' *) } '}' ;
paren_comment   = '(*' { (* any char except closing '*)' *) } '*)' ;
line_comment    = '//' { (* any char except newline *) } newline ;

(* Comments do NOT nest.                                            *)
(* { outer { inner } ← first } closes the comment.                 *)
(* A `{` immediately followed by `$` is not a comment: the lexer    *)
(* reports an error for that sequence. *)

(* ---- Keywords (62, case-insensitive) --------------------------- *)

keyword         = 'program'   | 'unit'      | 'uses'      | 'const'
                | 'var'       | 'mutable'   | 'function'  | 'procedure'
                | 'begin'     | 'end'       | 'return'    | 'if'
                | 'then'      | 'else'      | 'case'      | 'of'
                | 'for'       | 'to'        | 'downto'    | 'in'
                | 'do'        | 'while'     | 'repeat'    | 'until'
                | 'and'       | 'or'        | 'not'       | 'xor'
                | 'div'       | 'mod'       | 'shl'       | 'shr'
                | 'true'      | 'false'     | 'type'      | 'record'
                | 'ref'       | 'new'       | 'with'
                | 'enum'      | 'array'     | 'panic'
                | 'break'     | 'continue'  | 'result'    | 'option'
                | 'ok'        | 'error'     | 'some'      | 'none'
                | 'try'       | 'public'    | 'private'
                | 'go'        | 'channel'   | 'select'    | 'default'
                | 'from'      | 'dict'      | 'interface' | 'implements'
                | 'extends' ;

(* ---- Symbols --------------------------------------------------- *)

symbol          = ':=' | '..' | '<>' | '<=' | '>='
                | ':'  | ';'  | ','  | '.'  | '('  | ')'  | '['  | ']'
                | '+'  | '-'  | '*'  | '/'  | '='  | '<'  | '>' ;

(* ---- Token ----------------------------------------------------- *)

token           = keyword | identifier | integer_literal
                | real_literal | string_literal | symbol ;

(* Keywords take priority over identifiers.                         *)
(* ':=' takes priority over ':' followed by '='.                    *)
(* '..' takes priority over '.' followed by '.'.                    *)
(* '<=' and '>=' take priority over '<'/'>' followed by '='.        *)
(* '<>' takes priority over '<' followed by '>'.                    *)


(* ================================================================ *)
(* PART 2 — SYNTACTIC GRAMMAR                                      *)
(* ================================================================ *)

(* Semicolons are SEPARATORS, not terminators.                      *)
(* No ';' is required before 'end', 'else', or 'until'.            *)

(* ---- 2.1 Program / Unit Structure ------------------------------ *)

compilation_unit    = program | unit ;

program             = program_heading
                      [ uses_clause ]
                      { program_declaration }
                      main_block '.' ;

program_heading     = 'program' identifier ';' ;

unit                = unit_heading
                      [ uses_clause ]
                      { unit_declaration } ;

unit_heading        = 'unit' qualified_id ';' ;

(* Units have no main block. They contain declarations only.        *)

(* uses_clause: each qualified_id names a unit to import. All symbols of the unit are brought into
   scope under their short (unqualified) name. If two units export the same short name, the name is
   ambiguous and the compiler reports an error at the point of use (not at the uses site). The fully
   qualified name always works as a fallback. The first segment `Std` is reserved for the
   implementation-defined standard library. User-defined units (when supported) must not use `Std` as
   the leading segment; only two-part standard names such as `Std.Console` are valid for `Std.*`. *)

uses_clause         = 'uses' qualified_id { ',' qualified_id } ';' ;

main_block          = 'begin' statement_list 'end' ;

(* ---- 2.2 Declarations ----------------------------------------- *)

program_declaration = const_block
                    | var_block
                    | mutable_var_block
                    | type_block
                    | function_decl
                    | procedure_decl ;

unit_declaration    = [ visibility ] program_declaration ;

visibility          = 'public' | 'private' ;

(* Default visibility is `public`. `public`/`private` control       *)
(* whether a symbol is exported from a unit. They are not valid in  *)
(* `program` files.                                                 *)

(* -- Constants -- *)
const_block         = 'const' const_def { const_def } ;
const_def           = identifier ':' type_expr ':=' expression ';' ;

(* The initializer must be compile-time known. Syntax allows a general *)
(* expression here; the semantic checker restricts it to literals,     *)
(* other constants, enum members, and pure operator combinations.      *)

(* -- Immutable variables -- *)
var_block           = 'var' var_def { var_def } ;
var_def             = identifier ':' type_expr ':=' expression ';' ;

(* -- Mutable variables -- *)
mutable_var_block   = 'mutable' 'var' var_def { var_def } ;

(* -- Type definitions -- *)
type_block          = 'type' type_def { type_def } ;
type_def            = identifier [ type_params ] '=' type_body ';' ;
type_body           = record_type
                    | enum_type
                    | interface_type
                    | type_expr ;

type_params         = '<' type_param { ',' type_param } '>' ;
type_param          = identifier [ ':' constraint_name ] ;
constraint_name     = 'Comparable' | 'Numeric' | 'Printable' ;

(* ---- 2.3 Type Expressions ------------------------------------- *)

type_expr           = 'ref' qualified_id [ 'of' type_arg_list ] (* shared ref *)
                    | 'array' 'of' type_expr            (* array type     *)
                    | 'dict' 'of' type_expr 'to' type_expr (* dict type    *)
                    | 'channel' 'of' type_expr           (* channel type   *)
                    | 'result' 'of' type_expr ',' type_expr  (* result type *)
                    | 'option' 'of' type_expr            (* option type    *)
                    | function_type                      (* function type  *)
                    | procedure_type                     (* procedure type *)
                    | qualified_id [ 'of' type_arg_list ] ; (* named type  *)

type_arg_list       = type_expr { ',' type_expr } ;

function_type       = 'function' '(' [ formal_type_list ] ')' ':' type_expr ;
procedure_type      = 'procedure' '(' [ formal_type_list ] ')' ;

formal_type_list    = formal_type_param { ';' formal_type_param } ;
formal_type_param   = [ 'mutable' ] identifier ':' type_expr ;

(* ---- 2.4 Record & Enum Types ---------------------------------- *)

record_type         = 'record'
                      { field_def | implements_clause | record_method }
                      'end' ;
field_def           = identifier ':' type_expr [ ':=' expression ] ';' ;

(* ':= expression' is an optional default value for the field.      *)
(* When a record literal omits a field that has a default, the      *)
(* compiler substitutes the default automatically.  Fields without  *)
(* a default must be supplied in every record literal.              *)

interface_name      = qualified_id [ 'of' type_arg_list ] ;

implements_clause   = 'implements' interface_name ';' ;

(* A record may have zero or more implements_clause entries.        *)
(* Nominal typing: explicit declaration is required; structural     *)
(* match alone is not enough.                                       *)

record_method       = function_decl
                    | procedure_decl ;

(* Record methods must declare Self as the first parameter, typed   *)
(* as the enclosing record. Callers use dot notation; Self is       *)
(* passed implicitly: A.DistanceTo(B) → Point.DistanceTo(A, B).    *)
(* Record methods may declare their own type_params via the shared  *)
(* function_decl / procedure_decl grammar.                          *)

enum_type           = 'enum' enum_member { enum_member } 'end' ;
enum_member         = identifier [ enum_fields | '=' integer_literal ] ';' ;
enum_fields         = '(' enum_field { ';' enum_field } ')' ;
enum_field          = identifier ':' type_expr ;

(* Variants may carry associated data (enum_fields) OR an explicit  *)
(* backing value, but not both. Fieldless variants in a data enum   *)
(* are constructed without parentheses: Shape.Point.                *)

(* ---- 2.4b Interface Types ------------------------------------- *)

interface_type      = 'interface'
                      [ 'extends' interface_name ';' ]
                      { interface_method_sig }
                      'end' ;

interface_method_sig = interface_function_sig
                     | interface_procedure_sig ;

interface_function_sig  = 'function'  identifier [ type_params ]
                          '(' [ param_list ] ')' ':' type_expr ';' ;

interface_procedure_sig = 'procedure' identifier [ type_params ]
                          '(' [ param_list ] ')' ';' ;

(* Interface bodies contain only signatures — no bodies, no fields. *)
(* Each method must declare Self as its first parameter, typed as   *)
(* the interface itself.                                            *)
(* Interface methods may also declare their own type_params.        *)
(* 'extends' inherits all parent-interface method signatures.       *)
(* Circular extends (A extends A, or A extends B extends A) is     *)
(* a semantic error.                                                *)

(* ---- 2.5 Functions & Procedures -------------------------------- *)

function_decl       = function_heading ';'
                      { nested_decl } 'begin' statement_list 'end' ';' ;

function_heading    = 'function' identifier [ type_params ]
                      '(' [ param_list ] ')' ':' type_expr ;

procedure_decl      = procedure_heading ';'
                      { nested_decl } 'begin' statement_list 'end' ';' ;

procedure_heading   = 'procedure' identifier [ type_params ]
                      '(' [ param_list ] ')' ;

param_list          = param_group { ';' param_group } ;
param_group         = [ 'mutable' ] identifier ':' type_expr ;

nested_decl         = function_decl
                    | procedure_decl ;

(* ---- 2.6 Statements ------------------------------------------- *)

statement_list      = [ statement { ';' statement } ] ;

statement           = block
                    | var_stmt
                    | mutable_var_stmt
                    | assignment_stmt
                    | return_stmt
                    | panic_stmt
                    | if_stmt
                    | case_stmt
                    | for_stmt
                    | for_in_stmt
                    | while_stmt
                    | repeat_stmt
                    | break_stmt
                    | continue_stmt
                    | go_stmt
                    | select_stmt
                    | call_stmt ;

block               = 'begin' statement_list 'end' ;

(* -- Inline variable declarations -- *)
var_stmt            = 'var' identifier ':' type_expr ':=' expression ;
mutable_var_stmt    = 'mutable' 'var' identifier ':' type_expr ':=' expression ;

(* -- Assignment -- *)
assignment_stmt     = designator ':=' expression ;

(* -- Return -- *)
return_stmt         = 'return' [ expression ] ;

(* In functions, 'return expr' sets the return value and exits.     *)
(* In procedures, bare 'return' exits without a value.              *)

(* -- Panic -- *)
panic_stmt          = 'panic' '(' expression ')' ;

(* -- If / Then / Else -- *)
if_stmt             = 'if' expression 'then' statement
                      [ 'else' statement ] ;

(* 'else if' is not a keyword — it is 'else' followed by another   *)
(* if_stmt. The dangling-else ambiguity resolves by binding 'else'  *)
(* to the nearest unmatched 'if'.                                   *)

(* -- Case / Of -- *)
case_stmt           = 'case' expression 'of'
                      case_arm { ';' case_arm } [ ';' ]
                      [ 'else' statement_list [ ';' ] ]
                      'end' ;

case_arm            = case_label_list [ 'if' expression ] ':' statement ;
case_label_list     = case_label { ',' case_label } ;
case_label          = destructure_label                  (* Result/Option  *)
                    | enum_pattern                       (* enum with data *)
                    | expression [ '..' expression ] ;  (* value/range    *)

destructure_label   = ( 'ok' | 'error' | 'some' ) '(' identifier ')'
                    | 'none' ;

enum_pattern        = qualified_id '(' pattern_arg { ',' pattern_arg } ')'
                    | qualified_id ;                     (* fieldless variant *)

pattern_arg         = identifier ;                       (* binding only   *)

(* Each field position in an enum pattern must be a plain identifier *)
(* binding — wildcards, literals, and nested patterns are not        *)
(* supported.  Use a guard clause for additional constraints:        *)
(*   Shape.Circle(R) if R > 10.0: ...                               *)
(*                                                                  *)
(* Value labels must be compile-time constants: integer, char,      *)
(* string, boolean, or enum literals. Ranges use '..'.              *)
(*                                                                  *)
(* Semantic disambiguation for guarded scalar bindings: in a scalar  *)
(* case arm, `Name if <boolean>:` binds the scrutinee to `Name`     *)
(* when the arm has exactly one bare identifier label and `Name`    *)
(* does not resolve to a compile-time constant or enum member.      *)
(* This shorthand is not valid for ranges or comma-separated label  *)
(* lists.                                                           *)
(* Destructure labels bind the inner value of Result/Option.        *)
(* Enum patterns match a variant and bind its fields positionally:  *)
(* Shape.Circle(R) binds Radius to R.                               *)
(*                                                                  *)
(* Guard clause ('if' expression) on an arm: the arm matches only   *)
(* when the label matches AND the guard evaluates to true. The      *)
(* guard expression may reference bindings introduced by the label. *)
(* Guards do NOT count toward exhaustiveness: a guarded arm for a   *)
(* variant does not satisfy coverage of that variant.               *)
(*                                                                  *)
(* Exhaustiveness: for enum, Result, and Option types, every        *)
(* variant must be covered or an 'else' branch must be present.     *)
(* The compiler reports an error for non-exhaustive matches.        *)

(* -- For Loop -- *)
for_stmt            = 'for' identifier ':' type_expr ':=' expression
                      ( 'to' | 'downto' ) expression
                      'do' statement ;

(* -- For-In Loop -- *)
(* Works for both array-of-T (yields elements) and dict-of-K-to-V  *)
(* (yields keys in insertion order). Loop variable is immutable.   *)
for_in_stmt         = 'for' identifier ':' type_expr 'in' expression
                      'do' statement ;

(* 'in' is a keyword; used only in for-in loops.                    *)

(* The loop variable is declared inline and is immutable within     *)
(* the loop body.                                                   *)

(* -- While Loop -- *)
while_stmt          = 'while' expression 'do' statement ;

(* -- Repeat / Until -- *)
repeat_stmt         = 'repeat' statement_list 'until' expression ;

(* -- Break / Continue -- *)
break_stmt          = 'break' ;
continue_stmt       = 'continue' ;

(* -- Go (spawn task) -- *)
go_call             = designator '(' [ arg_list ] ')' ;
go_stmt             = 'go' go_call ;

(* `go` launches a concurrent task. Only call syntax is valid.      *)
(* As an expression, `go f()` returns                                *)
(* a `task` handle.                                                 *)

(* -- Select (channel multiplexing) -- *)
select_stmt         = 'select'
                                 ( select_arm { select_arm }
                                    [ 'default' ':' statement_list [ ';' ] ]
                                 | 'default' ':' statement_list [ ';' ] )
                                 'end' ;

select_arm          = 'case' identifier ':' type_expr 'from' expression
                      ':' statement ';' ;

(* Each arm tries a non-blocking receive from its channel.          *)
(* The first arm with an available value executes.                  *)
(* The binding identifier receives the value.                       *)
(* `default` runs when no channel has data.                         *)
(* Empty `select end` is invalid.                                   *)

(* -- Procedure / Function Call (statement position) -- *)
call_stmt           = designator '(' [ arg_list ] ')' ;

(* ---- 2.7 Expressions ------------------------------------------ *)

(* Operator precedence (highest → lowest), classical Pascal:        *)
(*                                                                  *)
(*   1. not, unary -                   prefix                       *)
(*   2. *  /  div  mod  and  shl  shr  multiplicative               *)
(*   3. +  -  or  xor                  additive                     *)
(*   4. =  <>  <  >  <=  >=  in       comparison                   *)

expression          = comparison_expr ;

comparison_expr     = additive_expr [ comparison_op additive_expr ] ;
comparison_op       = '=' | '<>' | '<' | '>' | '<=' | '>=' ;

additive_expr       = mult_expr { additive_op mult_expr } ;
additive_op         = '+' | '-' | 'or' | 'xor' ;

mult_expr           = unary_expr { mult_op unary_expr } ;
mult_op             = '*' | '/' | 'div' | 'mod' | 'and' | 'shl' | 'shr' ;

unary_expr          = 'not' unary_expr
                    | '-' unary_expr
                    | 'try' unary_expr                   (* error propagation *)
                    | primary_expr [ record_update ] ;

record_update       = 'with' field_init { field_init } 'end' ;

(* record_update is a postfix operator that produces a new record   *)
(* value identical to the base except for the overridden fields.    *)
(* The base expression must have a record type. Unknown or wrong-   *)
(* typed field overrides are compile-time errors.                   *)
(* Example: P with X := 10; end — produces a copy of P with X = 10 *)

primary_expr        = integer_literal
                    | real_literal
                    | string_literal
                    | 'true'
                    | 'false'
                    | 'ok' '(' expression ')'            (* Result Ok      *)
                    | 'error' '(' expression ')'        (* Result Error   *)
                    | 'some' '(' expression ')'          (* Option Some    *)
                    | 'none'                             (* Option None    *)
                    | '(' expression ')'
                    | array_literal
                    | dict_literal
                    | record_literal
                    | new_expr
                    | 'go' go_call                       (* spawn task     *)
                    | designator [ call_args ] ;

(* -- Function call -- *)
call_args           = '(' [ arg_list ] ')' ;

(* -- Record construction -- *)
record_literal      = 'record' { field_init } 'end' ;

(* Zero field_inits is valid when every field of the target type    *)
(* has a default value: var P: Point := record end;                 *)
new_expr            = 'new' type_expr 'with' field_init { field_init } 'end' ;
field_init          = identifier ':=' expression ';' ;

(* `new` is valid only when `type_expr` resolves to a record type. *)

arg_list            = expression { ',' expression } ;

(* -- Array literal -- *)
array_literal       = '[' [ expression { ',' expression } ] ']' ;

(* -- Dict literal -- *)
dict_literal        = '[' ( ':' ']'                                      (* empty dict [:] *)
                        | expression ':' expression
                          { ',' expression ':' expression } ']' ) ;

(* -- Designator (variable, field, or indexed access) -- *)
(* Index expression '[' expression ']' applies to: array (integer index),
   dict (key of matching type), and string (integer index → char).        *)
designator          = identifier { '.' identifier | '[' expression ']' } ;

(* -- Qualified identifier (for uses, types — no indexing) -- *)
qualified_id        = identifier { '.' identifier } ;

(* ================================================================ *)
(* END OF GRAMMAR                                                   *)
(* ================================================================ *)
